{
  "name": "gdr-zombie",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm db:bundle && nuxt build",
    "dev": "pnpm db:bundle && nuxt dev",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "typecheck": "pnpm db:bundle && nuxt typecheck",
    "test": "pnpm db:bundle && vitest run",
    "test:watch": "pnpm db:bundle && vitest",
    "test:coverage": "pnpm db:bundle && vitest run --coverage",
    "db:generate": "drizzle-kit generate && pnpm db:bundle",
    "db:migrate": "drizzle-kit migrate",
    "db:bundle": "tsx scripts/bundle-migrations.ts"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.102",
    "@iconify-json/simple-icons": "^1.2.78",
    "@nuxt/ui": "^4.6.1",
    "@pinia/nuxt": "^0.11.3",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "drizzle-orm": "^0.45.2",
    "nuxt": "^4.4.2",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/test-utils": "^4.0.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@vitest/coverage-v8": "^4.1.5",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.6"
  },
  "packageManager": "pnpm@10.33.0"
}
