{
  "name": "gdr-zombie",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm db:bundle && nuxt build",
    "dev": "nuxt dev",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "typecheck": "pnpm db:bundle && nuxt typecheck",
    "test": "pnpm db:bundle && vitest run",
    "test:watch": "pnpm db:bundle && vitest",
    "test:coverage": "pnpm db:bundle && vitest run --coverage",
    "db:generate": "drizzle-kit generate && pnpm db:bundle",
    "db:migrate": "drizzle-kit migrate && tsx scripts/seed-superadmin.ts",
    "db:bundle": "tsx scripts/bundle-migrations.ts",
    "smoke": "tsx scripts/smoke-load.ts"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.102",
    "@iconify-json/simple-icons": "^1.2.78",
    "@nuxt/ui": "^4.6.1",
    "@pinia/nuxt": "^0.11.3",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "drizzle-orm": "^0.45.2",
    "nuxt": "^4.4.2",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/test-utils": "^4.0.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/test-utils": "^2.4.6",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.0",
    "happy-dom": "^20.9.0",
    "playwright": "^1.59.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.6",
    "ws": "^8.20.0"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "vue": "3.5.33",
      "@vue/runtime-core": "3.5.33",
      "@vue/runtime-dom": "3.5.33",
      "@vue/reactivity": "3.5.33",
      "@vue/shared": "3.5.33",
      "@vue/compiler-core": "3.5.33",
      "@vue/compiler-dom": "3.5.33",
      "@vue/server-renderer": "3.5.33"
    }
  }
}
